{
  "name": "wata-board-security-tests",
  "version": "1.0.0",
  "description": "Comprehensive security testing suite for Wata-Board project",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "test:security": "jest --testPathPattern=security",
    "test:owasp": "jest --testPathPattern=owasp",
    "test:penetration": "jest --testPathPattern=penetration",
    "test:audit": "node scripts/audit.js",
    "test:vulnerability": "node scripts/vulnerability-scan.js",
    "test:all": "npm run test:audit && npm run test:vulnerability && npm run test:security && npm run test:owasp && npm run test:penetration",
    "report:security": "node scripts/generate-security-report.js",
    "scan:dependencies": "node scripts/dependency-scan.js",
    "scan:code": "node scripts/code-security-scan.js"
  },
  "keywords": ["security", "testing", "owasp", "penetration", "audit"],
  "author": "Security Team",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.6.0",
    "express": "^4.18.2",
    "helmet": "^7.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "supertest": "^6.3.4",
    "puppeteer": "^21.0.0",
    "zaproxy": "^2.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@types/express": "^4.17.17",
    "@types/cors": "^2.8.13",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "eslint-plugin-security": "^1.7.1"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/tests"],
    "testMatch": ["**/__tests__/**/*.ts", "**/?(*.)+(spec|test).ts"],
    "collectCoverageFrom": [
      "tests/**/*.{ts,js}",
      "!tests/**/*.d.ts"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": ["text", "lcov", "html"]
  }
}
